/* History records page styles */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #c3cfe2 100%);
  padding-bottom: 40rpx;
}

/* ========== Header bar ========== */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  margin: 20rpx 30rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.record-count {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.clear-btn {
  padding: 10rpx 24rpx;
  background: #fff0f0;
  border-radius: 20rpx;
  border: 1rpx solid #ffcdd2;
  transition: background 0.2s;
}

.clear-btn:active {
  background: #ffcdd2;
}

.clear-text {
  font-size: 24rpx;
  color: #f5576c;
  font-weight: 500;
}

/* ========== History list ========== */
.history-list {
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.card-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

/* ========== History card ========== */
.history-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.3s ease, background 0.2s;
  position: relative;
  z-index: 1;
}

.history-card:active {
  background: #f8f9fa;
}

.history-card.swiped {
  transform: translateX(-160rpx);
}

.card-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Card header */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
  margin-left: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.card-type.type-commercial {
  background: #eef2ff;
  color: #1677FF;
}

.card-type.type-fund {
  background: #e8f5e9;
  color: #4caf50;
}

.card-type.type-combination {
  background: #fff3e0;
  color: #f57c00;
}

/* Card body */
.card-body {
  display: flex;
  gap: 40rpx;
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.highlight-value {
  font-size: 32rpx;
  color: #1677FF;
  font-weight: bold;
}

/* Card footer */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-time {
  font-size: 24rpx;
  color: #bbbbbb;
}

.card-footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-tap-hint {
  font-size: 22rpx;
  color: #1677FF;
}

.card-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #f5f7fa;
  color: #999999;
  border-radius: 12rpx;
}

/* ========== Swipe delete button ========== */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #f5576c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
  z-index: 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.delete-btn.show {
  opacity: 1;
}

.delete-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

/* ========== Empty state ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  margin: 40rpx 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.btn-go-calculate {
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 20rpx 60rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.4);
}

.btn-go-calculate::after {
  border: none;
}
