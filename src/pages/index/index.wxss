/* 房贷计算器主页面样式 */

/* ========== 数据更新时间横幅 ========== */
.data-freshness-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 20rpx 0;
  padding: 16rpx 24rpx;
  background: rgba(22, 119, 255, 0.08);
  border-radius: 12rpx;
  transition: background 0.2s;
}

.data-freshness-banner:active {
  background: rgba(22, 119, 255, 0.15);
}

.freshness-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.freshness-text {
  font-size: 24rpx;
  color: #666666;
  white-space: nowrap;
}

.freshness-tag {
  flex-shrink: 0;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  margin-right: 12rpx;
}

.freshness-tag.fresh {
  background: rgba(76, 217, 100, 0.15);
  color: #34a853;
}

.freshness-tag.warning {
  background: rgba(255, 193, 7, 0.15);
  color: #d49200;
}

.freshness-tag.outdated {
  background: rgba(255, 59, 48, 0.15);
  color: #ea4335;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.freshness-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.source-text {
  font-size: 24rpx;
  color: #1677FF;
  white-space: nowrap;
}

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #c3cfe2 100%);
  padding-bottom: 40rpx;
}

/* ========== 分区样式 ========== */
.section {
  margin: 30rpx 30rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

/* ========== 城市选择 ========== */
.city-section {
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #ffffff;
}

.city-section .section-title {
  color: #ffffff;
}

.city-selector {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  margin-top: 20rpx;
  transition: background 0.2s;
}

.city-selector:active,
.city-selector-hover {
  background: rgba(255, 255, 255, 0.25);
}

.city-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.city-level {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  margin-right: auto;
}

.arrow {
  font-size: 32rpx;
  color: #ffffff;
}

.city-info {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.info-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* ========== 贷款类型 ========== */
.loan-type-tabs {
  display: flex;
  gap: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666666;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.tab.active {
  color: #1677FF;
  background: #eef2ff;
  border-color: #1677FF;
  font-weight: bold;
}

/* ========== 输入框 ========== */
.input-group {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 24rpx 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
}

.label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.input-number {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  text-align: right;
  min-width: 0;
}

.unit {
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== Quick Templates ========== */
.quick-templates-section {
  background: #ffffff;
}

.templates-row {
  display: flex;
  gap: 16rpx;
}

.template-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
  transition: all 0.3s;
}

.template-card:active {
  background: #eef2ff;
  border-color: #1677FF;
}

.template-card.template-active {
  background: #eef2ff;
  border-color: #1677FF;
}

.template-card.template-active .template-name {
  color: #1677FF;
}

.template-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.template-desc {
  font-size: 20rpx;
  color: #999999;
  text-align: center;
  line-height: 1.4;
}

/* ========== Input Validation ========== */
.input-hint {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 10rpx;
  padding-left: 4rpx;
}

.input-hint.hint-error {
  color: #e53935;
}

.input-group.input-error {
  border-color: #e53935;
}

/* ========== 按钮组 ========== */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin: 40rpx 30rpx 0;
}

.btn-calculate {
  flex: 2;
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.4);
  transition: opacity 0.2s;
}

.btn-calculate:active {
  opacity: 0.85;
  box-shadow: 0 4rpx 10rpx rgba(22, 119, 255, 0.3);
}

.btn-reset {
  flex: 1;
  background: #f5f7fa;
  color: #666666;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 28rpx 0;
  transition: background 0.2s;
}

.btn-reset:active {
  background: #e9ecef;
}

/* ========== 结果展示 ========== */
.result-section {
  margin: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item.highlight {
  background: linear-gradient(135deg, #1677FF15 0%, #0052D915 100%);
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: none;
}

.result-label {
  font-size: 28rpx;
  color: #666666;
}

.result-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.result-item.highlight .result-value {
  font-size: 40rpx;
  color: #1677FF;
}

.btn-detail {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #ffa726 0%, #fb8c00 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 24rpx 0;
  transition: opacity 0.2s;
}

.btn-detail:active {
  opacity: 0.85;
}

/* ========== 其他样式 ========== */
.house-type-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.selector-item {
  display: flex;
  align-items: center;
}

.radio-label {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  font-size: 28rpx;
  color: #666666;
}

.radio-label radio {
  margin-right: 12rpx;
}

.down-payment-info {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.info-text {
  font-size: 26rpx;
  color: #1677FF;
  font-weight: 500;
}

.fund-tip {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #fff3e0;
  border-radius: 12rpx;
  border-left: 4rpx solid #ffa726;
}

.tip-text {
  font-size: 24rpx;
  color: #f57c00;
}

.year-selector {
  display: flex;
  gap: 20rpx;
}

.year-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666666;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.year-item.active {
  color: #1677FF;
  background: #eef2ff;
  border-color: #1677FF;
  font-weight: bold;
}

.method-label {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.method-label radio {
  margin-right: 16rpx;
}

.method-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.method-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.method-desc {
  font-size: 24rpx;
  color: #999999;
}

.safety-line {
  margin-top: 30rpx;
  padding: 24rpx;
  background: #e8f5e9;
  border-radius: 16rpx;
  border-left: 4rpx solid #4caf50;
}

.safety-title {
  font-size: 28rpx;
  color: #2e7d32;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.safety-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.safety-item {
  font-size: 26rpx;
  color: #388e3c;
}

.safety-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.safety-status.safe {
  background: #c8e6c9;
  color: #2e7d32;
}

.safety-status.warning {
  background: #fff9c4;
  color: #f57f17;
}

.safety-status.danger {
  background: #ffcdd2;
  color: #c62828;
}

.safety-status.info {
  background: #e3f2fd;
  color: #1565c0;
}

/* ========== History entry button ========== */
.history-entry {
  display: flex;
  align-items: center;
  margin: 20rpx 30rpx 0;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: background 0.2s;
}

.history-entry:active,
.history-entry-hover {
  background: #f5f7fa;
}

.history-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.history-arrow {
  font-size: 28rpx;
  color: #cccccc;
}
