/* 还款方式对比页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx 30rpx 40rpx;
}

/* 输入区域 */
.input-section {
  margin-bottom: 30rpx;
}

.input-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 城市选择 */
.city-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #1677FF15 0%, #0052D915 100%);
  border-radius: 12rpx;
  border: 2rpx solid #1677FF;
  transition: opacity 0.2s;
}

.city-selector:active {
  opacity: 0.7;
}

.city-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1677FF;
}

.arrow {
  font-size: 40rpx;
  color: #1677FF;
  font-weight: bold;
}

/* 贷款类型选择 */
.loan-type-tabs {
  display: flex;
  gap: 16rpx;
}

.tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #ffffff;
  font-weight: bold;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: border 0.3s;
}

.input-row:focus-within {
  border-color: #1677FF;
  background: #ffffff;
}

.input-field {
  flex: 1;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: #333333;
}

.input-unit {
  font-size: 28rpx;
  color: #999999;
  margin-left: 12rpx;
}

/* 年限选择器 */
.years-selector {
  display: flex;
  gap: 16rpx;
}

.year-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s;
}

.year-item.active {
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #ffffff;
  font-weight: bold;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-reset {
  flex: 1;
  background: #f5f7fa;
  color: #1677FF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 24rpx 0;
  border: 2rpx solid #1677FF;
  transition: background 0.2s;
}

.btn-reset:active {
  background: #e9ecef;
}

.btn-compare {
  flex: 2;
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 24rpx 0;
  border: none;
  transition: opacity 0.2s;
}

.btn-compare:active {
  opacity: 0.85;
}

.btn-reset::after,
.btn-compare::after {
  border: none;
}

/* 对比结果区域 */
.result-section {
  margin-top: 30rpx;
}

/* 对比卡片容器 */
.comparison-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.compare-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.compare-card.left {
  border-top: 6rpx solid #1677FF;
}

.compare-card.right {
  border-top: 6rpx solid #0052D9;
}

/* 卡片头部 */
.card-header {
  padding: 30rpx 20rpx 20rpx;
  background: linear-gradient(180deg, rgba(22, 119, 255, 0.05) 0%, transparent 100%);
}

.method-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  text-align: center;
}

.method-desc {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
}

/* 卡片内容 */
.card-body {
  padding: 20rpx;
}

.data-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.data-item.highlight {
  background: linear-gradient(135deg, #1677FF15 0%, #0052D915 100%);
  border: 2rpx solid #1677FF;
}

.data-label {
  font-size: 24rpx;
  color: #999999;
}

.data-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.data-value.primary {
  color: #1677FF;
  font-size: 36rpx;
}

.data-value.warning {
  color: #f5576c;
}

.data-value.success {
  color: #20c997;
}

/* 优缺点 */
.pros-cons {
  margin-top: 20rpx;
}

.pros,
.cons {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 12rpx;
}

.point {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.6;
  margin-bottom: 6rpx;
  padding-left: 8rpx;
}

/* 对比总结 */
.comparison-summary {
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
}

.summary-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 24rpx;
}

.summary-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-item {
  background: rgba(255, 255, 255, 0.15);
  padding: 20rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.summary-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.summary-value.highlight {
  font-size: 32rpx;
  color: #ffd700;
}

.recommendation {
  background: rgba(255, 255, 255, 0.2);
  padding: 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.recommendation-icon {
  font-size: 36rpx;
}

.recommendation-text {
  flex: 1;
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.6;
}

/* 对比表格 */
.comparison-table {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.table-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.table-container {
  overflow: hidden;
  border-radius: 12rpx;
  border: 2rpx solid #e9ecef;
}

/* 表头 */
.table-header {
  display: flex;
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  padding: 20rpx 0;
}

.th {
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #ffffff;
}

.th-label {
  flex: 1.2;
}

.th-value {
  flex: 1;
}

/* 表格内容 */
.table-body {
  background: #ffffff;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #e9ecef;
  padding: 20rpx 0;
}

.table-row:last-child {
  border-bottom: none;
}

.td {
  text-align: center;
  font-size: 24rpx;
  color: #333333;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.td-label {
  flex: 1.2;
  font-weight: bold;
  color: #666666;
}

.td-value {
  flex: 1;
}

.td-value.warning {
  color: #f5576c;
  font-weight: bold;
}

.td-value.success {
  color: #20c997;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-top: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}
